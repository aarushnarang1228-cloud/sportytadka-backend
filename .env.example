# ===========================================
# SportyTadka Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Database
# Local dev: SQLite (zero setup, just works)
DATABASE_URL=sqlite+aiosqlite:///./sportytadka.db
# Production (Render): uncomment below and comment out SQLite line
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sportytadka

# Cricket Data API
# Sign up at https://cricapi.com/ for a free key (100 requests/day)
CRICKET_API_KEY=6f5050ab-124f-47fb-b189-77f95321509c
CRICKET_API_BASE_URL=https://api.cricapi.com/v1

# Gemini AI (Google AI Studio — free tier)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyA5kQzGjMUyY1_GoS2c5qWkerkgpn1xG88

# App Settings
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://sportytadka.vercel.app

# Polling Intervals (seconds)
LIVE_MATCH_POLL_INTERVAL=30
UPCOMING_MATCH_POLL_INTERVAL=300
